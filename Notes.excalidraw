		{
			"id": "wWxNNQFa",
			"type": "text",
			"x": -89.47561433767032,
			"y": -186.32679252055812,
			"width": 842.3654870597475,
			"height": 200,
			"angle": 0,
			"strokeColor": "#1e1e1e",
			"backgroundColor": "transparent",
			"fillStyle": "solid",
			"strokeWidth": 1,
			"strokeStyle": "solid",
			"roughness": 0,
			"opacity": 100,
			"groupIds": [
				"Z5_nwVSeBAAo7KFivKjTT"
