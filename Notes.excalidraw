			"version": 454,
			"versionNonce": 1425198863,
			"isDeleted": false,
			"boundElements": [],
			"updated": 1774189231091,
			"link": null,
			"locked": true,
			"text": "Consistency (move from 1 valid state to another): This is very much related\nto constraints. We cannot satisfy all constraints, but we can do our best.",
			"rawText": "Consistency (move from 1 valid state to another): This is very much related to constraints. We cannot satisfy all constraints, but we can do our best.",
			"fontSize": 20,
			"fontFamily": 5,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "Consistency (move from 1 valid state to another): This is very much related to constraints. We cannot satisfy all constraints, but we can do our best.",
			"autoResize": false,
			"lineHeight": 1.25
		},
		{
			"id": "AxUmyFcu",
			"type": "text",
