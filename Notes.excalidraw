		{
			"id": "eb01v947",
			"type": "text",
			"x": 876.8431122266356,
			"y": -647.2701509447053,
			"width": 746.6765945378052,
			"height": 100,
			"angle": 0,
			"strokeColor": "#1e1e1e",
			"backgroundColor": "transparent",
			"fillStyle": "solid",
			"strokeWidth": 1,
