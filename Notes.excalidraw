			"roundness": null,
			"seed": 2056431659,
			"version": 656,
			"versionNonce": 914724719,
			"isDeleted": false,
			"boundElements": [
				{
					"id": "yTdVWG0MKOir59fT6JsOm",
					"type": "arrow"
				}
			],
			"updated": 1774189231091,
			"link": null,
			"locked": true,
			"text": "MVCC\nVersion Chain: In the storage Engine, kinda like a Linked-List which showcase a linear history of that key. Usually they have a txn id associated along every version\nSnapshots: Which record the info about the state of all txns at a particular point in time so as to refer back to it. \nGarbage Collector: Pretty important otherwise you'd end up with older versions of the data constently and run out of space in your  storage engine.",
			"rawText": "MVCC\nVersion Chain: In the storage Engine, kinda like a Linked-List which showcase a linear history of that key. Usually they have a txn id associated along every version\nSnapshots: Which record the info about the state of all txns at a particular point in time so as to refer back to it. \nGarbage Collector: Pretty important otherwise you'd end up with older versions of the data constently and run out of space in your  storage engine.",
			"fontSize": 20,
			"fontFamily": 5,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "MVCC\nVersion Chain: In the storage Engine, kinda like a Linked-List which showcase a linear history of that key. Usually they have a txn id associated along every version\nSnapshots: Which record the info about the state of all txns at a particular point in time so as to refer back to it. \nGarbage Collector: Pretty important otherwise you'd end up with older versions of the data constently and run out of space in your  storage engine.",
			"autoResize": false,
			"lineHeight": 1.25
		},
