			"updated": 1774189231091,
			"link": null,
			"locked": true,
			"text": "Phantom Read/Repeatable read\nWhen T1 reads a set of rows by the same condition\ntwice and get different number of rows back. It is\nfunctionally the same as Repeatable Read anamoly.",
			"rawText": "Phantom Read/Repeatable read\nWhen T1 reads a set of rows by the same condition twice and get different number of rows back. It is functionally the same as Repeatable Read anamoly.",
			"fontSize": 20,
			"fontFamily": 5,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "Phantom Read/Repeatable read\nWhen T1 reads a set of rows by the same condition twice and get different number of rows back. It is functionally the same as Repeatable Read anamoly.",
			"autoResize": false,
			"lineHeight": 1.25
		},
