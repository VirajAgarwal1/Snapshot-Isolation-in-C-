			],
			"updated": 1774189231091,
			"link": null,
			"locked": true,
			"text": "Write Skew\nThis one is caused by our need for a constraint satisfaction. The common example given to explain this to\nstate the joint account problem, where you can withdraw from account A as if it was a A+B instead.\n\nThis anamoly is so hard to fix that unless you go full Serialisable mode, its pretty much always going to\nhappen.",
			"rawText": "Write Skew\nThis one is caused by our need for a constraint satisfaction. The common example given to explain this to state the joint account problem, where you can withdraw from account A as if it was a A+B instead.\n\nThis anamoly is so hard to fix that unless you go full Serialisable mode, its pretty much always going to happen.",
			"fontSize": 20,
			"fontFamily": 5,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "Write Skew\nThis one is caused by our need for a constraint satisfaction. The common example given to explain this to state the joint account problem, where you can withdraw from account A as if it was a A+B instead.\n\nThis anamoly is so hard to fix that unless you go full Serialisable mode, its pretty much always going to happen.",
			"autoResize": false,
			"lineHeight": 1.25
		},
