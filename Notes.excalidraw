				}
			],
			"updated": 1774189231091,
			"link": null,
			"locked": true,
			"text": "2PL\nLock Table: Which maintains shared_mutex locks for each key in the dataabse.\nWait queues: Which lets txns know if they have a chance at being granted that lock they want or not\nWait-for-graph: All Dbs ultimately maintain a wait graph of needed resources requests among txns so as to avoid a deadlock.",
			"rawText": "2PL\nLock Table: Which maintains shared_mutex locks for each key in the dataabse.\nWait queues: Which lets txns know if they have a chance at being granted that lock they want or not\nWait-for-graph: All Dbs ultimately maintain a wait graph of needed resources requests among txns so as to avoid a deadlock.",
			"fontSize": 20,
			"fontFamily": 5,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "2PL\nLock Table: Which maintains shared_mutex locks for each key in the dataabse.\nWait queues: Which lets txns know if they have a chance at being granted that lock they want or not\nWait-for-graph: All Dbs ultimately maintain a wait graph of needed resources requests among txns so as to avoid a deadlock.",
			"autoResize": true,
			"lineHeight": 1.25
		},
