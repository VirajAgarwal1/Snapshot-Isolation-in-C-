			"isDeleted": false,
			"boundElements": [],
			"updated": 1774189231091,
			"link": null,
			"locked": true,
			"text": "Atomicity (all or nothing): Transfer funds from A to B. Subtract 100 from A\nand Add 100 to B. If error occurs in between, then we get a problem.",
			"rawText": "Atomicity (all or nothing): Transfer funds from A to B. Subtract 100 from A and Add 100 to B. If error occurs in between, then we get a problem.",
			"fontSize": 20,
			"fontFamily": 5,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "Atomicity (all or nothing): Transfer funds from A to B. Subtract 100 from A and Add 100 to B. If error occurs in between, then we get a problem.",
			"autoResize": false,
			"lineHeight": 1.25
		},
		{
			"id": "G1QTsW3S",
