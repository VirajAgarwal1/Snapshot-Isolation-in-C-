			],
			"frameId": null,
			"index": "b7CI",
			"roundness": null,
			"seed": 2027516363,
			"version": 378,
			"versionNonce": 34697377,
			"isDeleted": false,
			"boundElements": [],
			"updated": 1774189231091,
			"link": null,
			"locked": true,
			"text": "Requests like the ones from API just dont have the same restrictions like\nabove. Also, a request can be idempotent as well. Same can be said about a\ntransaction. So, ultimately it comes down a preference. Because these are\nso different in application terms, we name them differently.",
			"rawText": "Requests like the ones from API just dont have the same restrictions like above. Also, a request can be idempotent as well. Same can be said about a transaction. So, ultimately it comes down a preference. Because these are so different in application terms, we name them differently.",
			"fontSize": 20,
			"fontFamily": 5,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "Requests like the ones from API just dont have the same restrictions like above. Also, a request can be idempotent as well. Same can be said about a transaction. So, ultimately it comes down a preference. Because these are so different in application terms, we name them differently.",
			"autoResize": false,
			"lineHeight": 1.25
		},
