			"isDeleted": false,
			"boundElements": [],
			"updated": 1774189231091,
			"link": null,
			"locked": true,
			"text": "Isolation: We dont want a transaction to keep considering what its concurrant transaction might\nbe doing. It should work similarly on concurrant setting as it would work in serial setting. A\ncounter example to Isolation would be that a txn is \"thinking\" ",
			"rawText": "Isolation: We dont want a transaction to keep considering what its concurrant transaction might be doing. It should work similarly on concurrant setting as it would work in serial setting. A counter example to Isolation would be that a txn is \"thinking\" ",
			"fontSize": 20,
			"fontFamily": 5,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "Isolation: We dont want a transaction to keep considering what its concurrant transaction might be doing. It should work similarly on concurrant setting as it would work in serial setting. A counter example to Isolation would be that a txn is \"thinking\" ",
			"autoResize": false,
			"lineHeight": 1.25
		},
