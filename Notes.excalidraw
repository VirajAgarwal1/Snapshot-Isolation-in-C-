			"frameId": null,
			"index": "b7Ce",
			"roundness": null,
			"seed": 1801959173,
			"version": 708,
			"versionNonce": 1670121199,
			"isDeleted": false,
			"boundElements": [],
			"updated": 1774189231091,
			"link": null,
			"locked": true,
			"text": "Reader-Writer lock (Shared mutex) but with the twist that the order of locking is\nfixed so that data race conditions don't occur. It has a growing phase where you\nalways start acquiring locks in order of least priority lock to highest priority and\nthen start releasing them in the opposite order. Also, after any unlock no new lock\ncan be acquired.\nThis is mimics Perfect Serialisable behaviour even in concurrent txns.\nA stricter version of this only releases locks on commits. To avoid aborts in txns\nwhich are working on the same data item at different time.",
			"rawText": "Reader-Writer lock (Shared mutex) but with the twist that the order of locking is fixed so that data race conditions don't occur. It has a growing phase where you always start acquiring locks in order of least priority lock to highest priority and then start releasing them in the opposite order. Also, after any unlock no new lock can be acquired.\nThis is mimics Perfect Serialisable behaviour even in concurrent txns.\nA stricter version of this only releases locks on commits. To avoid aborts in txns which are working on the same data item at different time.",
			"fontSize": 20,
			"fontFamily": 5,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "Reader-Writer lock (Shared mutex) but with the twist that the order of locking is fixed so that data race conditions don't occur. It has a growing phase where you always start acquiring locks in order of least priority lock to highest priority and then start releasing them in the opposite order. Also, after any unlock no new lock can be acquired.\nThis is mimics Perfect Serialisable behaviour even in concurrent txns.\nA stricter version of this only releases locks on commits. To avoid aborts in txns which are working on the same data item at different time.",
			"autoResize": false,
			"lineHeight": 1.25
		},
